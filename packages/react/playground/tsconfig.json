{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "declaration": false,
    "declarationMap": false,
    "isolatedDeclarations": false,
    "noEmit": true,
    "rootDir": "../..",
    "paths": {
      "@lorion-org/provider-selection": ["../../provider-selection/src/index.ts"],
      "@lorion-org/react": ["../src/index.ts"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "vite.config.ts",
    "capabilities/**/*.ts",
    "capabilities/**/*.tsx"
  ]
}
